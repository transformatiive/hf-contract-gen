              "leftValue": "={{ $json.mode }}",
              "rightValue": "one",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "Get_Deal",
      "name": "Get Deal",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        -120
      ],
      "parameters": {
        "url": "=https://www.zohoapis.eu/crm/v6/Deals/{{ $json.deal_id }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "Deal_Name,Company,End_Customer_Name,Contract_Aircraft,Contract_Start_Date,Contract_End_Date,Lease_Rate_p_BH,Charter_Type,Category"
            }
          ]
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "zohoOAuth2Api",
        "options": {}
      },
