        }
      },
      "webhookId": "818cb41b-36ee-48ea-a938-0ab0a374fee5"
    },
    {
      "id": "router",
      "name": "Router",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -40,
        0
      ],
      "parameters": {
        "jsCode": "\n// Decide: list deals (no id) or fetch one deal\nconst q = $json.query || {};\nconst dealId = (q.deal_id || '').toString().trim();\nreturn [{ json: { deal_id: dealId, mode: dealId ? 'one' : 'list' } }];\n"
      }
    },
    {
      "id": "iff",
