              "name": "per_page",
              "value": "50"
            },
            {
              "name": "fields",
              "value": "Deal_Name,Company,End_Customer_Name,Contract_Aircraft,Contract_Start_Date,Contract_End_Date,Lease_Rate_p_BH,Charter_Type,Category"
            },
            {
              "name": "sort_by",
              "value": "Modified_Time"
            },
            {
              "name": "sort_order",
              "value": "desc"
            }
          ]
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "zohoOAuth2Api",
        "options": {}
      },
      "credentials": {
        "zohoOAuth2Api": {
          "id": "DRXhp7RqsC8lAGeA",
          "name": "Zoho CRM HiFly"
        }
      }
    },
    {
      "id": "listc",
      "name": "Build List",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        620,
        120
      ],
      "parameters": {
        "jsCode": "\nconst deals = $('List Deals').first().json.data || [];\nreturn [{ json: { status:'ok', mode:'list', count: deals.length,\n  deals: deals.map(d=>({ id:d.id, name:d.Deal_Name, company:d.Company,\n    start:d.Contract_Start_Date, end:d.Contract_End_Date,\n    aircraft:(d.Contract_Aircraft&&d.Contract_Aircraft.name)||null })) } }];\n"
      }
    },
    {
      "id": "resp2",
      "name": "Respond List",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
