    },
    {
      "id": "Get_Aircraft",
      "name": "Get Aircraft",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        620,
        -120
      ],
      "parameters": {
        "url": "=https://www.zohoapis.eu/crm/v6/Aircrafts/{{ ($json.data && $json.data[0] && $json.data[0].Contract_Aircraft) ? $json.data[0].Contract_Aircraft.id : '0' }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "fields",
              "value": "Aircraft_Type,Tail_Nr,MSN,Name"
            }
          ]
        },
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "zohoOAuth2Api",
        "options": {
          "response": {}
        }
      },
      "credentials": {
        "zohoOAuth2Api": {
          "id": "DRXhp7RqsC8lAGeA",
          "name": "Zoho CRM HiFly"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "id": "build",
      "name": "Build Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        840,
        -120
      ],
      "parameters": {
        "jsCode": "\n// Build merge payload from the Deal (+ expanded aircraft) for the ACMI template.\nconst deal = $('Get Deal').first().json.data ? ($('Get Deal').first().json.data[0]||{}) : {};\nlet acft = {};\ntry { acft = ($('Get Aircraft').first().json.data || [{}])[0] || {}; } catch(e) {}\n\nconst fmtDate = (d) => {\n  if(!d) return '';\n  const dt = new Date(d);\n  if(isNaN(dt)) return d;\n  return dt.toLocaleDateString('en-GB',{day:'2-digit',month:'long',year:'numeric'});\n};\nconst money = (n) => (n===null||n===undefined||n==='') ? '' : ('USD ' + Number(n).toLocaleString('en-US'));\n\n// Contract_Aircraft.name looks like \"A330-300 - 9H-HFA\"\nconst caName = (deal.Contract_Aircraft && deal.Contract_Aircraft.name) || '';\nconst [caType, caReg] = caName.split(' - ').map(s=>(s||'').trim());\n\nconst zoho = {\n  // ---- pulled straight from Zoho CRM ----\n  agreement_no:    deal.Deal_Name || '',\n  lessee_name:     deal.Company || (deal.End_Customer_Name && deal.End_Customer_Name.name) || '',\n  ac_type:         acft.Aircraft_Type || caType || '',\n  ac_reg:          acft.Tail_Nr || caReg || '',\n  ac_msn:          (acft.MSN!==undefined && acft.MSN!==null) ? String(acft.MSN) : '',\n  delivery_date:   fmtDate(deal.Contract_Start_Date),\n  redelivery_date: fmtDate(deal.Contract_End_Date),\n  wet_lease_price: money(deal.Lease_Rate_p_BH),\n};\n\nreturn [{ json: {\n  status: 'ok',\n  deal_id: deal.id || '',\n  deal_name: deal.Deal_Name || '',\n  source: 'zoho-crm-hifly',\n  fetched_at: new Date().toISOString(),\n  fields: zoho,\n  raw: { deal, aircraft: acft }\n}}];\n"
      }
    },
    {
      "id": "resp1",
      "name": "Respond One",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1060,
        -120
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify($json) }}",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      }
    },
